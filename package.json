{
  "name": "migratorosaurus",
  "version": "2.0.0",
  "description": "An exotically simple database migration tool for Node postgres!",
  "author": "gabts",
  "license": "MIT",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabts/migratorosaurus.git"
  },
  "bugs": {
    "url": "https://github.com/gabts/migratorosaurus/issues"
  },
  "keywords": [
    "pg",
    "postgres",
    "database",
    "migration"
  ],
  "files": [
    "bin/cli.js",
    "dist/**/*",
    "!dist/**/*.test.*"
  ],
  "bin": {
    "migratorosaurus": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "test": "mocha --verbose --spec \"dist/**/*.test.js\"",
    "format": "prettier --write ."
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
