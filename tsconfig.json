{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "lib": ["ES2023"],
    "module": "node20",
    "noEmitOnError": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2023",
    "types": ["node", "mocha"]
  },
  "include": ["src"]
}
